# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — org player payments (Stripe Connect)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe — Fieldday platform subscription billing
# STRIPE_SECRET_KEY above is reused for platform billing (same Fieldday Stripe account)
STRIPE_PLATFORM_WEBHOOK_SECRET=
# Stripe Price IDs — create monthly prices in Stripe dashboard, then paste here
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_CLUB_MONTHLY=price_

# ── Platform Stripe test/live switch (optional) ──────────────────────────────
# To let a Platform Admin flip between test and live Stripe WITHOUT editing
# Railway each time, provide BOTH key sets with _LIVE and _TEST suffixes. The
# active mode is stored in platform_settings.platform_stripe_mode and toggled
# from Super Console → Settings. The unsuffixed vars above are treated as LIVE,
# and the default mode is 'live', so existing setups keep working unchanged.
#
#   STRIPE_SECRET_KEY_LIVE / STRIPE_SECRET_KEY_TEST
#   STRIPE_PLATFORM_WEBHOOK_SECRET_LIVE / STRIPE_PLATFORM_WEBHOOK_SECRET_TEST
#   STRIPE_PRICE_STARTER_MONTHLY_LIVE / _TEST  (and PRO, CLUB, HIBERNATE)
#
# Configure TWO platform webhook endpoints in Stripe (one in test mode, one in
# live) both pointing at the same /api/stripe/platform-webhook URL; the app
# verifies incoming events against both signing secrets automatically.

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@fielddayapp.ca

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cron — secret that external schedulers must send as: Authorization: Bearer <secret>
CRON_SECRET=

# Platform
NEXT_PUBLIC_PLATFORM_DOMAIN=fielddayapp.ca
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Railway — custom domain automation
# When an org saves a custom domain, Fieldday calls Railway's API to register it
# automatically (which triggers TLS cert provisioning). Without this var the
# admin must add domains manually in the Railway dashboard.
#   RAILWAY_API_TOKEN — Railway dashboard → Account Settings (avatar) → Tokens → Create token
#
# NOTE: RAILWAY_SERVICE_ID and RAILWAY_ENVIRONMENT_ID are automatically injected
# by Railway at runtime — do NOT set them manually; Railway will warn you if you try.
RAILWAY_API_TOKEN=
