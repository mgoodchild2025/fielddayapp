# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — org player payments (Stripe Connect)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe — Fieldday platform subscription billing
# STRIPE_SECRET_KEY above is reused for platform billing (same Fieldday Stripe account)
STRIPE_PLATFORM_WEBHOOK_SECRET=
# Stripe Price IDs — create monthly prices in Stripe dashboard, then paste here
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_CLUB_MONTHLY=price_

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@fielddayapp.ca

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Cron — secret that external schedulers must send as: Authorization: Bearer <secret>
CRON_SECRET=

# Platform
NEXT_PUBLIC_PLATFORM_DOMAIN=fielddayapp.ca
NEXT_PUBLIC_APP_URL=http://localhost:3000
